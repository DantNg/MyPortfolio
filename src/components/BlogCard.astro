---
import { formatDateShort } from '../utils/formatDate';
import { getReadingTime } from '../utils/readingTime';
import { url } from '../utils/url';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  coverImage?: string;
  body: string;
  featured?: boolean;
}

const { title, description, date, tags, slug, coverImage, body, featured } = Astro.props;
const readingTime = getReadingTime(body);
---

<article class="group relative flex flex-col rounded-2xl border border-zinc-800/60 bg-zinc-900/40 hover:bg-zinc-900/70 hover:border-zinc-700 transition-all duration-300 overflow-hidden hover:-translate-y-1 hover:shadow-xl hover:shadow-black/30">
  {featured && (
    <div class="absolute top-3 left-3 z-10">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-brand-950 border border-brand-800 text-brand-300">
        Featured
      </span>
    </div>
  )}

  {coverImage ? (
    <div class="aspect-video overflow-hidden bg-zinc-800">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="aspect-video bg-gradient-to-br from-zinc-900 to-zinc-800 flex items-center justify-center border-b border-zinc-800">
      <svg class="w-12 h-12 text-zinc-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
    </div>
  )}

  <div class="flex flex-col flex-1 p-6">
    <div class="flex items-center gap-2 text-xs text-zinc-500 mb-3">
      <time datetime={date.toISOString()}>{formatDateShort(date)}</time>
      <span>·</span>
      <span>{readingTime}</span>
    </div>

    <h3 class="font-semibold text-white text-lg mb-2 leading-snug group-hover:text-brand-400 transition-colors line-clamp-2">
      <a href={url(`/blog/${slug}`)} class="after:absolute after:inset-0">
        {title}
      </a>
    </h3>

    <p class="text-sm text-zinc-400 leading-relaxed flex-1 mb-4 line-clamp-3">{description}</p>

    <div class="flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map(tag => (
        <a href={url(`/blog?tag=${tag}`)} class="relative z-10 tag hover:bg-brand-900 transition-colors">
          #{tag}
        </a>
      ))}
      {tags.length > 3 && (
        <span class="tag">+{tags.length - 3}</span>
      )}
    </div>
  </div>
</article>
