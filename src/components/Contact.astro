---
import { SITE, SOCIALS } from '../config';
import { t } from '../i18n';

const username = SOCIALS.github.split('/').filter(Boolean).pop() ?? SITE.githubUsername;

const channels = [
  SOCIALS.github && { label: 'GitHub', value: `@${username}`, href: SOCIALS.github, external: true, accent: false, icon: '<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>', fill: true },
  SOCIALS.facebook && { label: 'Facebook', value: 'Message me', href: SOCIALS.facebook, external: true, accent: false, icon: '<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>', fill: true },
  SOCIALS.linkedin && { label: 'LinkedIn', value: SITE.name, href: SOCIALS.linkedin, external: true, accent: false, icon: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>', fill: true },
].filter(Boolean) as { label: string; value: string; href: string; external: boolean; icon: string; fill: boolean }[];
---

<section id="contact" class="py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16" data-animate>
      <p class="text-brand-400 font-mono text-sm mb-3 tracking-widest uppercase" data-i18n="contact.eyebrow">{t('contact.eyebrow')}</p>
      <h2 class="section-heading" data-i18n="contact.heading">{t('contact.heading')}</h2>
      <p class="section-subheading" data-i18n="contact.subheading">
        {t('contact.subheading')}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
      <!-- Contact info -->
      <div class="space-y-6" data-animate>
        <div class="card">
          <h3 class="font-semibold text-white mb-6" data-i18n="contact.getInTouch">{t('contact.getInTouch')}</h3>
          <div class="space-y-4">
            <a href={`mailto:${SITE.email}`} class="flex items-center gap-4 group">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-brand-950 border border-brand-900 flex items-center justify-center text-brand-400 group-hover:bg-brand-900 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-zinc-500 mb-0.5">Email</p>
                <p class="text-sm text-zinc-200 group-hover:text-brand-400 transition-colors">{SITE.email}</p>
              </div>
            </a>

            {channels.map(c => (
              <a href={c.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
                <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-400 group-hover:bg-zinc-700 transition-colors">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" set:html={c.icon} />
                </div>
                <div>
                  <p class="text-xs text-zinc-500 mb-0.5">{c.label}</p>
                  <p class="text-sm text-zinc-200 group-hover:text-brand-400 transition-colors">{c.value}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="card">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-sm font-medium text-white" data-i18n="contact.available.title">{t('contact.available.title')}</span>
          </div>
          <p class="text-sm text-zinc-400">
            <span data-i18n="contact.available.body">{t('contact.available.body')}</span> <span class="text-zinc-300">{SITE.location}.</span>
          </p>
        </div>
      </div>

      <!-- Contact form -->
      <div data-animate>
        <form
          class="card space-y-4"
          id="contact-form"
          action="https://formspree.io/f/yourformid"
          method="POST"
        >
          <h3 class="font-semibold text-white mb-2" data-i18n="contact.form.title">{t('contact.form.title')}</h3>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-xs font-medium text-zinc-400 mb-1.5" data-i18n="contact.form.name">{t('contact.form.name')}</label>
              <input type="text" id="name" name="name" required class="input" placeholder="John Doe" data-i18n-ph="contact.form.namePh" />
            </div>
            <div>
              <label for="email" class="block text-xs font-medium text-zinc-400 mb-1.5" data-i18n="contact.form.email">{t('contact.form.email')}</label>
              <input type="email" id="email" name="email" required class="input" placeholder="john@example.com" data-i18n-ph="contact.form.emailPh" />
            </div>
          </div>

          <div>
            <label for="subject" class="block text-xs font-medium text-zinc-400 mb-1.5" data-i18n="contact.form.subject">{t('contact.form.subject')}</label>
            <input type="text" id="subject" name="subject" required class="input" placeholder="Project inquiry..." data-i18n-ph="contact.form.subjectPh" />
          </div>

          <div>
            <label for="message" class="block text-xs font-medium text-zinc-400 mb-1.5" data-i18n="contact.form.message">{t('contact.form.message')}</label>
            <textarea id="message" name="message" required rows="5" class="input resize-none" placeholder="Tell me about your project..." data-i18n-ph="contact.form.messagePh"></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
            <span data-i18n="contact.form.send">{t('contact.form.send')}</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
