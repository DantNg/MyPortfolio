---
import { SITE, SOCIALS } from '../config';
import { t } from '../i18n';
import { url } from '../utils/url';

const year = new Date().getFullYear();

const navItems = [
  ['nav.about', '/about'],
  ['nav.projects', '/projects'],
  ['nav.repos', '/repos'],
  ['nav.blog', '/blog'],
  ['nav.resume', '/resume'],
  ['nav.contact', '/contact'],
];

const socialLinks = [
  { key: 'github', label: 'GitHub', href: SOCIALS.github, icon: '<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>' },
  { key: 'facebook', label: 'Facebook', href: SOCIALS.facebook, icon: '<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>' },
  { key: 'linkedin', label: 'LinkedIn', href: SOCIALS.linkedin, icon: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>' },
].filter(s => s.href);
---

<footer class="border-t border-zinc-800/60 bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-md bg-brand-600 flex items-center justify-center text-xs font-bold text-white">{SITE.initials}</div>
          <span class="font-semibold text-white">{SITE.name}</span>
        </div>
        <p class="text-sm text-zinc-400 leading-relaxed">
          <span class="font-medium text-zinc-300">{SITE.title}</span> <span data-i18n="footer.tagline">{t('footer.tagline')}</span>
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white mb-3" data-i18n="footer.nav">{t('footer.nav')}</h3>
        <ul class="space-y-2">
          {navItems.map(([key, href]) => (
            <li>
              <a href={url(href)} data-i18n={key} class="text-sm text-zinc-400 hover:text-white transition-colors">{t(key)}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white mb-3" data-i18n="footer.connect">{t('footer.connect')}</h3>
        <ul class="space-y-2">
          {socialLinks.map(s => (
            <li>
              <a href={s.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" set:html={s.icon} />
                {s.label}
              </a>
            </li>
          ))}
          <li>
            <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {SITE.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-zinc-800/60 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm text-zinc-500">
        &copy; {year} {SITE.name}. <span data-i18n="footer.built">{t('footer.built')}</span> <a href="https://astro.build" target="_blank" class="text-zinc-400 hover:text-white transition-colors">Astro</a> &amp; <a href="https://tailwindcss.com" target="_blank" class="text-zinc-400 hover:text-white transition-colors">Tailwind</a>.
      </p>
      <p class="text-xs text-zinc-600 font-mono" data-i18n="footer.motto">
        {t('footer.motto')}
      </p>
    </div>
  </div>
</footer>
