---
import { SITE } from '../config';
import { t } from '../i18n';
import { url } from '../utils/url';

// Tách tên: chữ cuối được tô màu gradient
const parts = SITE.name.trim().split(' ');
const firstName = parts.slice(0, -1).join(' ');
const lastName = parts.length > 1 ? parts[parts.length - 1] : '';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background effects -->
  <div class="absolute inset-0 bg-grid-pattern bg-grid opacity-40 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-radial-glow pointer-events-none" aria-hidden="true"></div>

  <!-- Animated blobs -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-brand-600/10 rounded-full blur-3xl animate-float pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-1/4 -right-32 w-80 h-80 bg-cyan-500/8 rounded-full blur-3xl animate-float animate-delay-300 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-800/60 bg-brand-950/60 text-brand-400 text-xs font-medium mb-8 animate-fade-in">
      <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
      <span data-i18n="hero.badge">{t('hero.badge')}</span>
    </div>

    <!-- Name -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-4 animate-slide-up">
      {firstName} <span class="gradient-text">{lastName}</span>
    </h1>

    <!-- Title -->
    <div class="flex items-center justify-center gap-3 mb-6 animate-slide-up animate-delay-100">
      <div class="h-px w-8 bg-zinc-700"></div>
      <p class="text-xl md:text-2xl font-medium text-zinc-300 font-mono">
        {SITE.title}
      </p>
      <div class="h-px w-8 bg-zinc-700"></div>
    </div>

    <!-- Introduction -->
    <p class="max-w-2xl mx-auto text-lg text-zinc-400 leading-relaxed mb-10 animate-slide-up animate-delay-200">
      {SITE.intro}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap items-center justify-center gap-4 mb-16 animate-slide-up animate-delay-300">
      <a href={url('/projects')} class="btn-primary text-base px-6 py-3">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m0 0l7-7m-7 7l7 7" />
        </svg>
        <span data-i18n="hero.cta.projects">{t('hero.cta.projects')}</span>
      </a>
      <a href={url('/blog')} class="btn-secondary text-base px-6 py-3">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <span data-i18n="hero.cta.articles">{t('hero.cta.articles')}</span>
      </a>
      <a href={url('/contact')} class="btn-secondary text-base px-6 py-3">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span data-i18n="hero.cta.contact">{t('hero.cta.contact')}</span>
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-2xl mx-auto animate-slide-up animate-delay-400">
      {[
        { value: '5+', key: 'hero.stat.experience' },
        { value: '20+', key: 'hero.stat.projects' },
        { value: '10+', key: 'hero.stat.platforms' },
        { value: '3', key: 'hero.stat.oss' },
      ].map(stat => (
        <div class="text-center">
          <div class="text-3xl font-bold text-white">{stat.value}</div>
          <div class="text-xs text-zinc-500 mt-1" data-i18n={stat.key}>{t(stat.key)}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <div class="w-6 h-10 rounded-full border-2 border-zinc-700 flex items-start justify-center p-1">
      <div class="w-1 h-2 bg-zinc-500 rounded-full animate-slide-up"></div>
    </div>
  </div>
</section>
