---
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';
import { t } from '../i18n';

const allPosts = await getCollection('blog', p => !p.data.draft);
const latest = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section id="blog" class="py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12" data-animate>
      <div>
        <p class="text-brand-400 font-mono text-sm mb-3 tracking-widest uppercase" data-i18n="blog.eyebrow">{t('blog.eyebrow')}</p>
        <h2 class="section-heading" data-i18n="blog.heading">{t('blog.heading')}</h2>
        <p class="section-subheading max-w-xl" data-i18n="blog.subheading">
          {t('blog.subheading')}
        </p>
      </div>
      <a href="/blog" class="btn-secondary flex-shrink-0">
        <span data-i18n="blog.viewAll">{t('blog.viewAll')}</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {latest.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
          slug={post.slug}
          coverImage={post.data.coverImage}
          body={post.body}
          featured={post.data.featured}
        />
      ))}
    </div>
  </div>
</section>
