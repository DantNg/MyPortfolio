---
import { SITE, SOCIALS } from '../config';
import { t } from '../i18n';
import { url } from '../utils/url';
import LanguageSwitcher from './LanguageSwitcher.astro';

const navLinks = [
  { key: 'nav.about', href: '/about' },
  { key: 'nav.projects', href: '/projects' },
  { key: 'nav.repos', href: '/repos' },
  { key: 'nav.blog', href: '/blog' },
  { key: 'nav.resume', href: '/resume' },
  { key: 'nav.contact', href: '/contact' },
];

const pathname = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={url('/')} class="group flex items-center gap-2 font-semibold text-white">
        <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-sm font-bold group-hover:bg-brand-500 transition-colors">
          {SITE.initials}
        </div>
        <span class="hidden sm:block text-sm tracking-wide">{SITE.name}</span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-1">
        {navLinks.map(link => {
          const linkUrl = url(link.href);
          const isActive = pathname === linkUrl || pathname.startsWith(linkUrl + '/');
          return (
            <li>
              <a
                href={linkUrl}
                data-i18n={link.key}
                class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-200 ${
                  isActive
                    ? 'bg-white/10 text-white'
                    : 'text-zinc-400 hover:text-white hover:bg-white/5'
                }`}
              >
                {t(link.key)}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <LanguageSwitcher />

        <a
          href={SOCIALS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-white/5 transition-all duration-200"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-white/5 transition-all duration-200"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-zinc-800 bg-zinc-950/95 backdrop-blur-xl"
  >
    <div class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      {navLinks.map(link => {
        const linkUrl = url(link.href);
        const isActive = pathname === linkUrl || pathname.startsWith(linkUrl + '/');
        return (
          <a
            href={linkUrl}
            data-i18n={link.key}
            class={`block px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
              isActive
                ? 'bg-white/10 text-white'
                : 'text-zinc-400 hover:text-white hover:bg-white/5'
            }`}
          >
            {t(link.key)}
          </a>
        );
      })}
      <div class="pt-2 border-t border-zinc-800">
        <a
          href={SOCIALS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-zinc-400 hover:text-white"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  let open = false;

  // Scrolled state
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('bg-zinc-950/90', 'backdrop-blur-xl', 'border-b', 'border-zinc-800/50', 'shadow-lg');
    } else {
      navbar?.classList.remove('bg-zinc-950/90', 'backdrop-blur-xl', 'border-b', 'border-zinc-800/50', 'shadow-lg');
    }
  }, { passive: true });

  toggle?.addEventListener('click', () => {
    open = !open;
    menu?.classList.toggle('hidden', !open);
    menuIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
