---
import { formatDateShort } from '../utils/formatDate';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  coverImage?: string;
  status: string;
  githubUrl?: string;
  demoUrl?: string;
  featured?: boolean;
}

const { title, description, date, tags, slug, coverImage, status, githubUrl, demoUrl, featured } = Astro.props;

const statusColors: Record<string, string> = {
  completed: 'bg-emerald-950 text-emerald-400 border-emerald-900',
  'in-progress': 'bg-amber-950 text-amber-400 border-amber-900',
  archived: 'bg-zinc-900 text-zinc-400 border-zinc-800',
};
---

<article class="group relative flex flex-col rounded-2xl border border-zinc-800/60 bg-zinc-900/40 hover:bg-zinc-900/70 hover:border-zinc-700 transition-all duration-300 overflow-hidden hover:-translate-y-1 hover:shadow-xl hover:shadow-black/30">
  {featured && (
    <div class="absolute top-3 right-3 z-10">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-brand-950 border border-brand-800 text-brand-300">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        Featured
      </span>
    </div>
  )}

  {coverImage ? (
    <div class="aspect-video overflow-hidden bg-zinc-800">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="aspect-video bg-gradient-to-br from-brand-950/60 to-zinc-900 flex items-center justify-center border-b border-zinc-800">
      <svg class="w-12 h-12 text-zinc-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
      </svg>
    </div>
  )}

  <div class="flex flex-col flex-1 p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border ${statusColors[status]}`}>
        {status === 'in-progress' ? 'In Progress' : status.charAt(0).toUpperCase() + status.slice(1)}
      </span>
      <span class="text-xs text-zinc-500">{formatDateShort(date)}</span>
    </div>

    <h3 class="font-semibold text-white text-lg mb-2 leading-snug group-hover:text-brand-400 transition-colors">
      <a href={`/projects/${slug}`} class="after:absolute after:inset-0">
        {title}
      </a>
    </h3>

    <p class="text-sm text-zinc-400 leading-relaxed flex-1 mb-4 line-clamp-3">{description}</p>

    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.slice(0, 4).map(tag => (
        <span class="tag">{tag}</span>
      ))}
      {tags.length > 4 && (
        <span class="tag">+{tags.length - 4}</span>
      )}
    </div>

    <div class="flex items-center gap-3 pt-4 border-t border-zinc-800">
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-10 flex items-center gap-1.5 text-xs text-zinc-400 hover:text-white transition-colors"
          aria-label="View on GitHub"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      )}
      {demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-10 flex items-center gap-1.5 text-xs text-zinc-400 hover:text-white transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Demo
        </a>
      )}
      <a href={`/projects/${slug}`} class="relative z-10 ml-auto flex items-center gap-1 text-xs text-brand-400 hover:text-brand-300 transition-colors font-medium">
        Read more
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</article>
