---
const events = [
  {
    year: '2024',
    title: 'Senior Embedded Engineer',
    company: 'TechCorp IoT Solutions',
    description: 'Leading firmware architecture for a fleet of 50,000+ connected industrial sensors. Designed BLE Mesh provisioning pipeline and OTA update system.',
    tags: ['BLE Mesh', 'Zephyr', 'nRF52840', 'OTA'],
  },
  {
    year: '2022',
    title: 'Embedded Software Engineer',
    company: 'DroneVentures Inc.',
    description: 'Developed PX4-based flight controller firmware for autonomous delivery drones. Implemented sensor fusion algorithms and MAVLink telemetry stack.',
    tags: ['PX4', 'STM32H7', 'FreeRTOS', 'MAVLink'],
  },
  {
    year: '2021',
    title: 'Firmware Engineer',
    company: 'ConnectedEdge Startup',
    description: 'Built LoRaWAN-connected environmental monitoring devices from schematic review through mass production firmware. Led bring-up of ESP32 + SX1276 hardware.',
    tags: ['ESP32', 'LoRaWAN', 'C', 'Docker'],
  },
  {
    year: '2019',
    title: 'Junior Embedded Developer',
    company: 'EmbedSys Labs',
    description: 'Maintained and extended bare-metal firmware for STM32-based motor controllers. Gained deep knowledge of timer peripherals, DMA, and HAL/LL drivers.',
    tags: ['STM32', 'C', 'Motor Control', 'CAN'],
  },
  {
    year: '2019',
    title: 'B.Sc. Electrical & Computer Engineering',
    company: 'University of Technology',
    description: 'Graduated with honors. Thesis: "Real-Time Sensor Fusion for UAV Attitude Estimation Using Extended Kalman Filter." Dean\'s List all semesters.',
    tags: ['EKF', 'MATLAB', 'PCB Design', 'FPGA'],
    isEducation: true,
  },
];
---

<section id="timeline" class="py-24 md:py-32 bg-zinc-950/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-brand-400 font-mono text-sm mb-3 tracking-widest uppercase" data-i18n="timeline.eyebrow">Career</p>
      <h2 class="section-heading" data-i18n="timeline.heading">Professional Timeline</h2>
      <p class="section-subheading max-w-xl mx-auto" data-i18n="timeline.subheading">
        A journey through embedded systems, from student projects to production firmware.
      </p>
    </div>

    <div class="relative max-w-3xl mx-auto">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-brand-600/60 via-zinc-700 to-transparent" aria-hidden="true"></div>

      <div class="space-y-10">
        {events.map((event, i) => (
          <div
            class={`relative flex gap-8 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-start`}
            data-animate
          >
            <!-- Dot -->
            <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full border-2 border-brand-500 bg-zinc-950 mt-2 z-10"></div>

            <!-- Year badge -->
            <div class={`hidden md:block w-[calc(50%-2rem)] ${i % 2 === 0 ? 'text-right pr-8' : 'text-left pl-8'}`}>
              <span class="inline-block px-3 py-1 rounded-full bg-brand-950 border border-brand-900 text-brand-400 text-sm font-mono font-medium">
                {event.year}
              </span>
            </div>

            <!-- Card -->
            <div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:pl-8' : 'md:pr-8'}`}>
              <div class="card">
                <div class="flex items-center gap-2 mb-1 md:hidden">
                  <span class="text-xs text-brand-400 font-mono">{event.year}</span>
                  {event.isEducation && (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-violet-950 text-violet-400 border border-violet-900">Education</span>
                  )}
                </div>
                <h3 class="font-semibold text-white">{event.title}</h3>
                <p class="text-sm text-brand-400 mt-0.5 mb-3">{event.company}</p>
                <p class="text-sm text-zinc-400 leading-relaxed mb-4">{event.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {event.tags.map(tag => (
                    <span class="tag text-xs">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
