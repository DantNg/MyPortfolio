---
const events = [
  {
    year: '2025',
    title: 'Automotive Developer',
    company: 'LG Electronics R&D Vietnam',
    description: 'Developing middleware services for LG automotive platforms in C++. Implemented IPC communication between system components using Android Binder, and built binary database services with backup & recovery mechanisms for reliable persistent storage.',
    tags: ['C++', 'Android Binder', 'IPC', 'Middleware', 'Automotive'],
  },
  {
    year: '2023',
    title: 'OS and Middleware Developer',
    company: 'FPT Software',
    description: 'Developed middleware APIs bridging applications and hardware components. Created and maintained automated tests for comprehensive coverage, and diagnosed/resolved memory-related issues to improve system stability and performance.',
    tags: ['C++', 'Middleware', 'Automated Testing', 'Embedded Linux'],
  },
  {
    year: '2023',
    title: 'Intern Developer',
    company: 'Viettel Aerospace Institute',
    description: 'Programmed FPGA and integrated sensors, ensuring efficient data communication between FPGA and IMU sensors. Designed a Qt desktop application to display data and control the FPGA circuit.',
    tags: ['FPGA', 'Qt', 'IMU', 'Sensors'],
  },
  {
    year: '2024',
    title: 'Master of Mechatronics',
    company: 'VNU – University of Engineering & Technology',
    description: 'Pursuing a Master\'s degree in Mechatronics (11/2024 – present), deepening expertise in control systems, robotics, and embedded engineering.',
    tags: ['Mechatronics', 'Control Systems', 'Robotics'],
    isEducation: true,
  },
  {
    year: '2019',
    title: 'B.Eng. Control & Automation Engineering',
    company: 'VNU – University of Engineering & Technology',
    description: 'Graduated in Control and Automation Engineering (9/2019 – 12/2023), GPA 3.27. Built a strong foundation in embedded systems, control theory, and electronics.',
    tags: ['Control', 'Automation', 'Embedded', 'GPA 3.27'],
    isEducation: true,
  },
];
---

<section id="timeline" class="py-24 md:py-32 bg-zinc-950/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-brand-400 font-mono text-sm mb-3 tracking-widest uppercase" data-i18n="timeline.eyebrow">Career</p>
      <h2 class="section-heading" data-i18n="timeline.heading">Professional Timeline</h2>
      <p class="section-subheading max-w-xl mx-auto" data-i18n="timeline.subheading">
        A journey through embedded systems, from student projects to production firmware.
      </p>
    </div>

    <div class="relative max-w-3xl mx-auto">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-brand-600/60 via-zinc-700 to-transparent" aria-hidden="true"></div>

      <div class="space-y-10">
        {events.map((event, i) => (
          <div
            class={`relative flex gap-8 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-start`}
            data-animate
          >
            <!-- Dot -->
            <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full border-2 border-brand-500 bg-zinc-950 mt-2 z-10"></div>

            <!-- Year badge -->
            <div class={`hidden md:block w-[calc(50%-2rem)] ${i % 2 === 0 ? 'text-right pr-8' : 'text-left pl-8'}`}>
              <span class="inline-block px-3 py-1 rounded-full bg-brand-950 border border-brand-900 text-brand-400 text-sm font-mono font-medium">
                {event.year}
              </span>
            </div>

            <!-- Card -->
            <div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:pl-8' : 'md:pr-8'}`}>
              <div class="card">
                <div class="flex items-center gap-2 mb-1 md:hidden">
                  <span class="text-xs text-brand-400 font-mono">{event.year}</span>
                  {event.isEducation && (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-violet-950 text-violet-400 border border-violet-900">Education</span>
                  )}
                </div>
                <h3 class="font-semibold text-white">{event.title}</h3>
                <p class="text-sm text-brand-400 mt-0.5 mb-3">{event.company}</p>
                <p class="text-sm text-zinc-400 leading-relaxed mb-4">{event.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {event.tags.map(tag => (
                    <span class="tag text-xs">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
