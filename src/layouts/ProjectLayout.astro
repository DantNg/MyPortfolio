---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/formatDate';
import { url } from '../utils/url';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    tags: string[];
    coverImage?: string;
    status: string;
    githubUrl?: string;
    demoUrl?: string;
  };
}

const { frontmatter } = Astro.props;

const statusColors: Record<string, string> = {
  completed: 'bg-emerald-950 text-emerald-400 border-emerald-900',
  'in-progress': 'bg-amber-950 text-amber-400 border-amber-900',
  archived: 'bg-zinc-900 text-zinc-400 border-zinc-800',
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.coverImage}
  type="article"
  tags={frontmatter.tags}
>
  <article class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class={`inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium border ${statusColors[frontmatter.status]}`}>
            {frontmatter.status === 'in-progress' ? 'In Progress' : frontmatter.status.charAt(0).toUpperCase() + frontmatter.status.slice(1)}
          </span>
          <time class="text-sm text-zinc-500" datetime={frontmatter.date.toISOString()}>
            {formatDate(frontmatter.date)}
          </time>
        </div>

        <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-4">
          {frontmatter.title}
        </h1>

        <p class="text-xl text-zinc-400 leading-relaxed mb-6">
          {frontmatter.description}
        </p>

        <div class="flex flex-wrap items-center gap-3">
          {frontmatter.githubUrl && (
            <a
              href={frontmatter.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
              </svg>
              View on GitHub
            </a>
          )}
          {frontmatter.demoUrl && (
            <a
              href={frontmatter.demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Live Demo
            </a>
          )}
        </div>

        <div class="flex flex-wrap gap-2 mt-6">
          {frontmatter.tags.map(tag => (
            <a href={url(`/projects?tag=${tag}`)} class="tag">
              {tag}
            </a>
          ))}
        </div>
      </header>

      {frontmatter.coverImage && (
        <div class="mb-12 rounded-2xl overflow-hidden border border-zinc-800">
          <img
            src={url(frontmatter.coverImage)}
            alt={frontmatter.title}
            class="w-full object-cover aspect-video"
            loading="eager"
          />
        </div>
      )}

      <div class="prose prose-invert prose-zinc max-w-none prose-custom">
        <slot />
      </div>

      <div class="mt-16 pt-8 border-t border-zinc-800">
        <a href={url('/projects')} class="btn-secondary inline-flex">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          <span data-i18n="common.backProjects">Back to all projects</span>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
