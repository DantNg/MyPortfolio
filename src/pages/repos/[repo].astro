---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRepos, getReadme } from '../../lib/github';
import { formatDateShort } from '../../utils/formatDate';

export async function getStaticPaths() {
  const repos = await getRepos();
  const paths = [];
  for (const repo of repos) {
    const readme = await getReadme(repo.slug, repo.defaultBranch);
    paths.push({
      params: { repo: repo.slug },
      props: { repo, readme },
    });
  }
  return paths;
}

const { repo, readme } = Astro.props;
---

<BaseLayout
  title={repo.name}
  description={repo.description ?? `${repo.name} — open-source repository on GitHub.`}
  type="article"
  tags={repo.topics}
>
  <article class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <header class="mb-10">
        <a href="/repos" class="inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-zinc-300 transition-colors mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          All repositories
        </a>

        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-3">{repo.name}</h1>
        {repo.description && <p class="text-lg text-zinc-400 leading-relaxed mb-5">{repo.description}</p>}

        <div class="flex flex-wrap items-center gap-4 text-sm text-zinc-500 mb-5">
          {repo.language && <span>{repo.language}</span>}
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
            {repo.stars} stars
          </span>
          <span>{repo.forks} forks</span>
          <span>Updated {formatDateShort(new Date(repo.updatedAt))}</span>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <a href={repo.htmlUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          {repo.homepage && (
            <a href={repo.homepage} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              Live Site
            </a>
          )}
        </div>

        {repo.topics.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-5">
            {repo.topics.map((t) => <span class="tag">{t}</span>)}
          </div>
        )}
      </header>

      <!-- README -->
      <div class="pt-8 border-t border-zinc-800">
        {readme.hasReadme ? (
          <div class="prose prose-invert prose-zinc max-w-none prose-custom" set:html={readme.html} />
        ) : (
          <p class="text-zinc-500">This repository has no README.</p>
        )}
      </div>
    </div>
  </article>
</BaseLayout>
