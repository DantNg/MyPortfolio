---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRepos } from '../../lib/github';
import { SITE, SOCIALS } from '../../config';
import { url } from '../../utils/url';

const repos = await getRepos();

// Màu chấm theo ngôn ngữ phổ biến
const langColors: Record<string, string> = {
  C: '#555555', 'C++': '#f34b7d', Python: '#3572A5', JavaScript: '#f1e05a',
  TypeScript: '#3178c6', Rust: '#dea584', Go: '#00ADD8', Shell: '#89e051',
  HTML: '#e34c26', CSS: '#563d7c', Java: '#b07219', Kotlin: '#A97BFF',
  Dart: '#00B4AB', Vue: '#41b883', Astro: '#ff5a03',
};
---

<BaseLayout
  title="Repos"
  description={`Open-source repositories by ${SITE.name}, fetched automatically from GitHub.`}
>
  <div class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="max-w-2xl mb-12" data-animate>
        <p class="text-brand-400 font-mono text-sm mb-3 tracking-widest uppercase">Open Source</p>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-4">GitHub Repositories</h1>
        <p class="text-xl text-zinc-400">
          {repos.length > 0
            ? `${repos.length} public repositories, pulled live from GitHub.`
            : 'Repositories will appear here once your GitHub username is set in src/config.ts.'}
        </p>
      </div>

      {repos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {repos.map((repo) => (
            <article class="group relative flex flex-col rounded-2xl border border-zinc-800/60 bg-zinc-900/40 hover:bg-zinc-900/70 hover:border-zinc-700 transition-all duration-300 p-6 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/30">
              <div class="flex items-start gap-3 mb-3">
                <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-400">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 010-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 011-1h8z"/></svg>
                </div>
                <h2 class="font-semibold text-white leading-snug group-hover:text-brand-400 transition-colors">
                  <a href={url(`/repos/${repo.slug}`)} class="after:absolute after:inset-0">{repo.name}</a>
                </h2>
              </div>

              <p class="text-sm text-zinc-400 leading-relaxed flex-1 mb-4 line-clamp-3">
                {repo.description ?? 'No description provided.'}
              </p>

              {repo.topics.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {repo.topics.slice(0, 4).map((t) => <span class="tag">{t}</span>)}
                </div>
              )}

              <div class="flex items-center gap-4 text-xs text-zinc-500 pt-4 border-t border-zinc-800">
                {repo.language && (
                  <span class="flex items-center gap-1.5">
                    <span class="w-2.5 h-2.5 rounded-full" style={`background:${langColors[repo.language] ?? '#9ca3af'}`}></span>
                    {repo.language}
                  </span>
                )}
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
                  {repo.stars}
                </span>
                <a href={repo.htmlUrl} target="_blank" rel="noopener noreferrer" class="relative z-10 ml-auto flex items-center gap-1 text-zinc-400 hover:text-white transition-colors">
                  GitHub
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="card max-w-2xl">
          <h3 class="font-semibold text-white mb-2">Chưa có repo nào hiển thị</h3>
          <ul class="text-sm text-zinc-400 space-y-2 list-disc list-inside">
            <li>Mở <code class="text-brand-300">src/config.ts</code> và đặt <code class="text-brand-300">githubUsername</code> thành username GitHub của bạn.</li>
            <li>Đảm bảo máy build có kết nối Internet (GitHub API).</li>
            <li>Nếu vượt giới hạn request, đặt biến môi trường <code class="text-brand-300">GITHUB_TOKEN</code>.</li>
          </ul>
          <a href={SOCIALS.github} target="_blank" rel="noopener noreferrer" class="btn-secondary mt-4 inline-flex">Mở GitHub của tôi</a>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
