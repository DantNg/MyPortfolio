---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SOCIALS } from '../config';
import { t } from '../i18n';
import { url } from '../utils/url';

const githubLabel = SOCIALS.github.replace(/^https?:\/\//, '');
---

<BaseLayout
  title="Resume"
  description="Professional resume of an Embedded Software Engineer with expertise in STM32, Nordic nRF, BLE Mesh, FreeRTOS, Zephyr, PX4, and LoRaWAN."
>
  <div class="py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-6 mb-12 pb-8 border-b border-zinc-800" data-animate>
        <div>
          <h1 class="text-4xl font-bold text-white mb-1">{SITE.name}</h1>
          <p class="text-xl text-brand-400 font-mono mb-3">{SITE.title}</p>
          <div class="flex flex-wrap gap-4 text-sm text-zinc-400">
            <span>📍 {SITE.location}</span>
            <a href={`tel:${SITE.phone}`} class="hover:text-white transition-colors">{SITE.phone}</a>
            <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors">{SITE.email}</a>
            <a href={SOCIALS.github} target="_blank" class="hover:text-white transition-colors">{githubLabel}</a>
          </div>
        </div>
        <a href={url('/resume.pdf')} download class="btn-primary flex-shrink-0 self-start">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <span data-i18n="resume.download">{t('resume.download')}</span>
        </a>
      </div>

      <!-- Summary -->
      <section class="mb-10" data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-4" data-i18n="resume.summary">{t('resume.summary')}</h2>
        <p class="text-zinc-300 leading-relaxed" data-i18n="resume.summaryBody">
          {t('resume.summaryBody')}
        </p>
      </section>

      <!-- Experience -->
      <section class="mb-10" data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-6" data-i18n="resume.experience">{t('resume.experience')}</h2>
        <div class="space-y-8">
          {[
            {
              title: 'Automotive Developer',
              company: 'LG Electronics R&D Vietnam',
              period: '01/2025 – Present',
              location: 'Hanoi',
              bullets: [
                'Developed middleware services for LG automotive platforms using C++.',
                'Implemented IPC communication between system components using Android Binder.',
                'Developed and maintained binary database services for persistent data storage.',
                'Implemented backup and recovery mechanisms to ensure data integrity and prevent corruption.',
                'Collaborated with platform and validation teams to integrate and troubleshoot software components.',
              ],
              tags: ['C++', 'Android Binder', 'IPC', 'Middleware', 'Automotive'],
            },
            {
              title: 'OS and Middleware Developer',
              company: 'FPT Software',
              period: '08/2023 – 01/2025',
              location: 'Hanoi',
              bullets: [
                'Developed middleware APIs to enable communication between applications and hardware components.',
                'Created and maintained automated tests to verify software functionality, ensuring comprehensive test coverage and improving reliability.',
                'Diagnosed and resolved memory-related issues in existing programs, enhancing stability and performance.',
              ],
              tags: ['C++', 'Middleware', 'Automated Testing', 'Embedded Linux'],
            },
            {
              title: 'Intern Developer',
              company: 'Viettel Aerospace Institute',
              period: '01/2023 – 06/2023',
              location: 'Hanoi',
              bullets: [
                'Programmed FPGA and integrated various sensors, ensuring efficient data communication between FPGA and IMU sensors.',
                'Designed and developed a Qt desktop application to display data and control the FPGA circuit, enhancing the user interface and control capabilities.',
              ],
              tags: ['FPGA', 'Qt', 'IMU', 'Sensors'],
            },
          ].map(job => (
            <div class="relative pl-4 border-l border-zinc-800">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 mb-3">
                <div>
                  <h3 class="font-semibold text-white">{job.title}</h3>
                  <p class="text-brand-400 text-sm">{job.company} · {job.location}</p>
                </div>
                <span class="text-xs text-zinc-500 font-mono whitespace-nowrap">{job.period}</span>
              </div>
              <ul class="space-y-1.5 mb-3">
                {job.bullets.map(b => (
                  <li class="text-sm text-zinc-400 leading-relaxed flex gap-2">
                    <span class="text-brand-500 mt-1.5 flex-shrink-0">▸</span>
                    {b}
                  </li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-1.5">
                {job.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section class="mb-10" data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-6" data-i18n="resume.education">{t('resume.education')}</h2>
        <div class="space-y-6">
          {[
            {
              degree: 'Master of Mechatronics',
              school: 'VNU – University of Engineering & Technology',
              period: '11/2024 – Present',
              desc: 'Advanced study in mechatronics, control systems, and embedded engineering.',
            },
            {
              degree: 'B.Eng. Control & Automation Engineering',
              school: 'VNU – University of Engineering & Technology',
              period: '09/2019 – 12/2023',
              desc: 'GPA 3.27. Foundation in embedded systems, control theory, and electronics.',
            },
          ].map(edu => (
            <div class="pl-4 border-l border-zinc-800">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 mb-2">
                <div>
                  <h3 class="font-semibold text-white">{edu.degree}</h3>
                  <p class="text-brand-400 text-sm">{edu.school}</p>
                </div>
                <span class="text-xs text-zinc-500 font-mono whitespace-nowrap">{edu.period}</span>
              </div>
              <p class="text-sm text-zinc-400">{edu.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Skills -->
      <section class="mb-10" data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-6" data-i18n="resume.skills">{t('resume.skills')}</h2>
        <div class="space-y-3">
          {[
            { label: 'Programming', value: 'C / C++, Python, Bash' },
            { label: 'Embedded', value: 'STM32, ESP32, FreeRTOS, Embedded Linux' },
            { label: 'Protocols', value: 'UART, SPI, I2C, CAN, RS485, TCP/IP' },
            { label: 'Wireless', value: 'BLE 5.0, WiFi, LoRa' },
            { label: 'Software', value: 'OOP, Multi-threading, IPC (Binder), Middleware, Data Management' },
            { label: 'Tools', value: 'Git, Jenkins, Jira, Codebeamer, VS Code, Qt Creator' },
          ].map(row => (
            <div class="grid grid-cols-[120px_1fr] gap-4 text-sm py-2 border-b border-zinc-800/50 last:border-0">
              <span class="text-zinc-500 font-medium">{row.label}</span>
              <span class="text-zinc-300">{row.value}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Languages -->
      <section data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-6" data-i18n="resume.languages">{t('resume.languages')}</h2>
        <div class="space-y-3">
          {[
            { name: 'English', level: 'Intermediate' },
            { name: 'Vietnamese', level: 'Native' },
          ].map(lng => (
            <div class="flex items-center justify-between text-sm py-2 border-b border-zinc-800/50 last:border-0">
              <span class="text-zinc-300 font-medium">{lng.name}</span>
              <span class="text-xs text-zinc-500 font-mono">{lng.level}</span>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
