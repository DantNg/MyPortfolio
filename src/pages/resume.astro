---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SOCIALS } from '../config';
import { t } from '../i18n';
import { url } from '../utils/url';

const githubLabel = SOCIALS.github.replace(/^https?:\/\//, '');
---

<BaseLayout
  title="Resume"
  description="Professional resume of an Embedded Software Engineer with expertise in STM32, Nordic nRF, BLE Mesh, FreeRTOS, Zephyr, PX4, and LoRaWAN."
>
  <div class="py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-6 mb-12 pb-8 border-b border-zinc-800" data-animate>
        <div>
          <h1 class="text-4xl font-bold text-white mb-1">{SITE.name}</h1>
          <p class="text-xl text-brand-400 font-mono mb-3">{SITE.title}</p>
          <div class="flex flex-wrap gap-4 text-sm text-zinc-400">
            <span>📍 {SITE.location}</span>
            <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors">{SITE.email}</a>
            <a href={SOCIALS.github} target="_blank" class="hover:text-white transition-colors">{githubLabel}</a>
          </div>
        </div>
        <a href={url('/resume.pdf')} download class="btn-primary flex-shrink-0 self-start">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <span data-i18n="resume.download">{t('resume.download')}</span>
        </a>
      </div>

      <!-- Summary -->
      <section class="mb-10" data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-4" data-i18n="resume.summary">{t('resume.summary')}</h2>
        <p class="text-zinc-300 leading-relaxed" data-i18n="resume.summaryBody">
          {t('resume.summaryBody')}
        </p>
      </section>

      <!-- Experience -->
      <section class="mb-10" data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-6" data-i18n="resume.experience">{t('resume.experience')}</h2>
        <div class="space-y-8">
          {[
            {
              title: 'Senior Embedded Engineer',
              company: 'TechCorp IoT Solutions',
              period: '2024 – Present',
              location: 'Remote',
              bullets: [
                'Led firmware architecture for a fleet of 50,000+ nRF52840-based industrial sensors, achieving 99.7% uptime over 6 months.',
                'Designed a BLE Mesh provisioning pipeline handling 200+ nodes per gateway, reducing on-site commissioning time by 60%.',
                'Implemented delta OTA update system reducing average update payload by 75% vs. full firmware flash.',
                'Mentored 3 junior firmware engineers; introduced unit testing with Unity framework increasing branch coverage from 40% to 85%.',
              ],
              tags: ['Zephyr', 'nRF52840', 'BLE Mesh', 'C', 'OTA'],
            },
            {
              title: 'Embedded Software Engineer',
              company: 'DroneVentures Inc.',
              period: '2022 – 2024',
              location: 'San Francisco, CA',
              bullets: [
                'Developed STM32H7-based flight controller firmware integrated with PX4 autopilot stack; achieved 1 kHz control loop with <5 µs jitter.',
                'Implemented EKF-based sensor fusion (IMU + GPS + optical flow) enabling GPS-denied indoor navigation.',
                'Optimized ESC communication protocol (DSHOT600 via DMA) improving motor response latency by 40%.',
                'Built MAVLink v2 telemetry stack; integrated with QGroundControl for mission planning and live telemetry.',
              ],
              tags: ['STM32H7', 'FreeRTOS', 'PX4', 'MAVLink', 'C++'],
            },
            {
              title: 'Firmware Engineer',
              company: 'ConnectedEdge Startup',
              period: '2021 – 2022',
              location: 'Austin, TX',
              bullets: [
                'Shipped LoRaWAN Class A environmental sensors (ESP32 + SX1276) achieving 12 km range and 8-month battery life.',
                'Built ChirpStack-based backend with Python rules engine for automated irrigation triggers.',
                'Reduced current consumption by 35% through peripheral power gating and optimized deep sleep wakeup sequences.',
              ],
              tags: ['ESP32', 'LoRaWAN', 'Python', 'Docker', 'MQTT'],
            },
          ].map(job => (
            <div class="relative pl-4 border-l border-zinc-800">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 mb-3">
                <div>
                  <h3 class="font-semibold text-white">{job.title}</h3>
                  <p class="text-brand-400 text-sm">{job.company} · {job.location}</p>
                </div>
                <span class="text-xs text-zinc-500 font-mono whitespace-nowrap">{job.period}</span>
              </div>
              <ul class="space-y-1.5 mb-3">
                {job.bullets.map(b => (
                  <li class="text-sm text-zinc-400 leading-relaxed flex gap-2">
                    <span class="text-brand-500 mt-1.5 flex-shrink-0">▸</span>
                    {b}
                  </li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-1.5">
                {job.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section class="mb-10" data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-6" data-i18n="resume.education">{t('resume.education')}</h2>
        <div class="pl-4 border-l border-zinc-800">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 mb-2">
            <div>
              <h3 class="font-semibold text-white" data-i18n="resume.edu.degree">{t('resume.edu.degree')}</h3>
              <p class="text-brand-400 text-sm" data-i18n="resume.edu.school">{t('resume.edu.school')}</p>
            </div>
            <span class="text-xs text-zinc-500 font-mono">2015 – 2019</span>
          </div>
          <p class="text-sm text-zinc-400" data-i18n="resume.edu.desc">
            {t('resume.edu.desc')}
          </p>
        </div>
      </section>

      <!-- Skills -->
      <section class="mb-10" data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-6" data-i18n="resume.skills">{t('resume.skills')}</h2>
        <div class="space-y-3">
          {[
            { label: 'Languages', value: 'C (expert), C++ (proficient), Python (proficient), Bash' },
            { label: 'RTOSes', value: 'FreeRTOS, Zephyr RTOS, ThreadX' },
            { label: 'MCU Platforms', value: 'STM32 (F0-H7 families), Nordic nRF52/nRF91, ESP32/ESP8266, Raspberry Pi' },
            { label: 'Wireless', value: 'BLE, BLE Mesh, LoRaWAN, WiFi (802.11), MQTT, CoAP' },
            { label: 'Interfaces', value: 'SPI, I2C, UART, USB (CDC/HID), CAN, RS-485, Modbus' },
            { label: 'Drone/Robotics', value: 'PX4, ArduPilot, MAVLink, QGroundControl, Sensor Fusion (EKF)' },
            { label: 'DevOps & Tools', value: 'Docker, Git, GitHub Actions, GDB, OpenOCD, Segger J-Link, Logic analyzer' },
          ].map(row => (
            <div class="grid grid-cols-[120px_1fr] gap-4 text-sm py-2 border-b border-zinc-800/50 last:border-0">
              <span class="text-zinc-500 font-medium">{row.label}</span>
              <span class="text-zinc-300">{row.value}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Certifications / Awards -->
      <section data-animate>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-6" data-i18n="resume.certs">{t('resume.certs')}</h2>
        <div class="space-y-3">
          {[
            { name: 'Arm Cortex-M Microcontroller Design', issuer: 'Udemy / Kiran Nayak', year: '2023' },
            { name: 'Bluetooth Low Energy Fundamentals', issuer: 'Nordic Semiconductor Academy', year: '2022' },
            { name: 'Best Hardware Hack', issuer: 'HackDFW 2021', year: '2021' },
          ].map(cert => (
            <div class="flex items-center justify-between text-sm py-2 border-b border-zinc-800/50 last:border-0">
              <div>
                <span class="text-zinc-300 font-medium">{cert.name}</span>
                <span class="text-zinc-500 ml-2">· {cert.issuer}</span>
              </div>
              <span class="text-xs text-zinc-600 font-mono">{cert.year}</span>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
